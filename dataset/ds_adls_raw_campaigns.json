{
  "name": "ds_adls_raw_campaigns",
  "type": "Microsoft.DataFactory/factories/datasets",
  "properties": {
    "description": "ADLS Gen2 staging for Marketo campaign activity JSON files",
    "linkedServiceName": { "referenceName": "ls_adls_gen2", "type": "LinkedServiceReference" },
    "type": "Json",
    "typeProperties": {
      "location": {
        "type": "AzureBlobFSLocation",
        "fileSystem": "retail-raw-stage",
        "folderPath": {
          "value": "campaigns/@{formatDateTime(pipeline().TriggerTime,'yyyy/MM/dd')}",
          "type": "Expression"
        },
        "fileName": {
          "value": "marketo_@{pipeline().RunId}.json",
          "type": "Expression"
        }
      }
    }
  }
}
