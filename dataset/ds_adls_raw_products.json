{
  "name": "ds_adls_raw_products",
  "type": "Microsoft.DataFactory/factories/datasets",
  "properties": {
    "description": "ADLS Gen2 staging for product catalog JSON from PIM REST API",
    "linkedServiceName": { "referenceName": "ls_adls_gen2", "type": "LinkedServiceReference" },
    "type": "Json",
    "typeProperties": {
      "location": {
        "type": "AzureBlobFSLocation",
        "fileSystem": "retail-raw-stage",
        "folderPath": {
          "value": "products/@{formatDateTime(pipeline().TriggerTime,'yyyy/MM/dd')}",
          "type": "Expression"
        },
        "fileName": {
          "value": "catalog_@{pipeline().RunId}.json",
          "type": "Expression"
        }
      }
    }
  }
}
