{
  "name": "ls_rest_orders_api",
  "type": "Microsoft.DataFactory/factories/linkedservices",
  "properties": {
    "description": "Order Management System REST API — incremental order extraction by last-modified timestamp",
    "type": "RestService",
    "typeProperties": {
      "url": "https://api.oms.internal/v2",
      "enableServerCertificateValidation": true,
      "authenticationType": "ClientCertificate",
      "clientCert": {
        "type": "AzureKeyVaultSecret",
        "store": { "referenceName": "ls_key_vault", "type": "LinkedServiceReference" },
        "secretName": "oms-api-client-cert"
      }
    },
    "annotations": ["oms", "orders", "rest-api"]
  }
}
