{
  "name": "tr_daily_load",
  "type": "Microsoft.DataFactory/factories/triggers",
  "properties": {
    "description": "Schedule trigger that fires the master daily orchestration pipeline at 02:00 UTC every day. Offset from midnight to allow Azure Functions micro-batch processing (which runs at 02:00 UTC) to flush its buffers first.",
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2024-01-01T02:00:00Z",
        "endTime": null,
        "timeZone": "UTC",
        "schedule": {
          "hours": [2],
          "minutes": [0]
        }
      }
    },
    "pipelines": [
      {
        "pipelineReference": {
          "referenceName": "pl_orchestrate_daily_load",
          "type": "PipelineReference"
        },
        "parameters": {}
      }
    ],
    "annotations": ["daily", "scheduled", "02:00-utc"]
  }
}
